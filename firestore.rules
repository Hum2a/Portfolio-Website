rules_version = '2';
// Portfolio Firestore: analytics/contact are writable by anyone (logged in or not) so tracking always works;
// reads + admin stay on role "humza". Schema notes: .cursor/firestore-schema.md
service cloud.firestore {
  match /databases/{database}/documents {

    function isHumza() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'humza';
    }

    function isSignedInUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function nonEmptyString(s, maxLen) {
      return s is string && s.size() > 0 && s.size() <= maxLen;
    }

    function optionalString(s, maxLen) {
      return s == null || (s is string && s.size() <= maxLen);
    }

    // --- users: self only; role fixed after create -----------------------------
    match /users/{userId} {
      allow get: if isSignedInUser(userId);
      allow list: if false;

      allow create: if isSignedInUser(userId)
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'photoURL', 'updatedAt', 'role', 'createdAt'])
        && request.resource.data.role == 'user'
        && optionalString(request.resource.data.email, 320)
        && optionalString(request.resource.data.displayName, 200)
        && optionalString(request.resource.data.photoURL, 2000)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;

      allow update: if isSignedInUser(userId)
        && request.resource.data.keys().hasOnly(['email', 'displayName', 'photoURL', 'updatedAt', 'role', 'createdAt'])
        && request.resource.data.role == resource.data.role
        && optionalString(request.resource.data.email, 320)
        && optionalString(request.resource.data.displayName, 200)
        && optionalString(request.resource.data.photoURL, 2000)
        && request.resource.data.updatedAt is timestamp;

      allow delete: if false;
    }

    // --- enquiries -------------------------------------------------------------
    match /enquiries/{enquiryId} {
      allow get, list: if isHumza();

      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'phone', 'enquiry', 'timestamp', 'status'])
        && nonEmptyString(request.resource.data.name, 200)
        && optionalString(request.resource.data.email, 320)
        && optionalString(request.resource.data.phone, 40)
        && nonEmptyString(request.resource.data.enquiry, 10000)
        && request.resource.data.status == 'new'
        && request.resource.data.timestamp is timestamp;

      allow update, delete: if isHumza();
    }

    // --- tracking tokens: list only for humza; click bump for anyone ---------
    match /analytics_tracking_tokens/{tokenId} {
      allow get: if tokenId.size() <= 64;
      allow list: if isHumza();

      allow create: if isHumza()
        && request.resource.data.keys().hasOnly(['token', 'source', 'medium', 'campaign', 'label', 'createdAt', 'clicks'])
        && request.resource.data.token == tokenId
        && nonEmptyString(request.resource.data.source, 120)
        && optionalString(request.resource.data.medium, 120)
        && optionalString(request.resource.data.campaign, 200)
        && optionalString(request.resource.data.label, 200)
        && request.resource.data.clicks == 0
        && request.resource.data.createdAt is timestamp;

      // Ref links must work whether the visitor is signed in or not.
      allow update: if isHumza()
        || (
          resource != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks', 'lastUsedAt'])
          && request.resource.data.clicks is int
          && request.resource.data.clicks >= resource.data.get('clicks', 0)
          && request.resource.data.clicks <= resource.data.get('clicks', 0) + 50
          && request.resource.data.lastUsedAt is timestamp
        );

      allow delete: if isHumza();
    }

    // --- analytics_stats: permissive writes; humza reads ----------------------
    match /analytics_stats/{statId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }

    // --- analytics_visitors + pageviews subcollection -------------------------
    match /analytics_visitors/{visitorDocId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();

      match /pageviews/{pageViewId} {
        allow get, list: if isHumza();
        allow create, update: if true;
        allow delete: if isHumza();
      }
    }

    match /analytics_pageviews/{pageViewId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }

    match /analytics_page_times/{timeDocId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }

    match /analytics_events/{eventId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }

    match /analytics_media_clicks/{clickId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }

    match /analytics_sessions/{sessionId} {
      allow get, list: if isHumza();
      allow create, update: if true;
      allow delete: if isHumza();
    }
  }
}
