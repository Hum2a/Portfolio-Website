rules_version = '2';
// Firestore rules for analytics_tracking_tokens
// Merge this block into your existing firestore.rules if you have one
service cloud.firestore {
  match /databases/{database}/documents {
    match /analytics_tracking_tokens/{tokenId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }
  }
}
